LLM_API_KEY=your_api_key_here
LLM_BASE_URL=
LLM_MODEL=anthropic.claude-sonnet-4-6

# The client is model-agnostic: point LLM_BASE_URL at any LLM endpoint that
# exposes a Chat Completions API and set LLM_MODEL to a model it serves.
#
# Example - Amazon Bedrock:
# LLM_API_KEY=<your Bedrock API key>
# LLM_BASE_URL=<your Bedrock endpoint URL>
# LLM_MODEL=anthropic.claude-sonnet-5

# Evaluation (SQL generator harness). When set to 1, the optional RAGAS
# LLMSQLEquivalence metric runs and reuses the LLM_* settings above. It is
# LLM-only (no embeddings) and never gates CI. Leave at 0 for the fast,
# deterministic-only eval. Requires: uv sync --extra eval
EVAL_RAGAS=0
